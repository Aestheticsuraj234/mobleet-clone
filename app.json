{
  "expo": {
    "name": "mobleet-clone",
    "slug": "mobleet-clone",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "mobleetclone",
    "userInterfaceStyle": "dark",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0c",
        "foregroundImage": "./assets/images/logo.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.codebysuraj.mobleet"
    },
    "web": {
      "output": "server",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-web-browser",
        {
          "experimentalLauncherActivity": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0a0a0c",
          "image": "./assets/images/logo.png",
          "imageWidth": 120,
          "android": {
            "image": "./assets/images/logo.png",
            "imageWidth": 120
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "3ceb8ff8-9dec-4ecf-9450-291214a17e81"
      }
    },
    "owner": "codebysuraj"
  }
}
